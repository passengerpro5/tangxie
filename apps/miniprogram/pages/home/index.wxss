.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 40rpx;
  background: linear-gradient(180deg, #fff7ed 0%, #fef3c7 100%);
  color: #1c1917;
  box-sizing: border-box;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.brand {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: #92400e;
  text-transform: uppercase;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
}

.subtitle {
  font-size: 26rpx;
  color: #57534e;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #78716c;
  font-size: 28rpx;
}

.tab-active {
  background: linear-gradient(135deg, #f59e0b, #ea580c);
  color: #fff;
  box-shadow: 0 18rpx 40rpx rgba(234, 88, 12, 0.24);
}

.panel {
  border-radius: 32rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 22rpx 48rpx rgba(120, 53, 15, 0.08);
  margin-bottom: 22rpx;
}

.panel-header {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
}

.panel-caption {
  font-size: 24rpx;
  color: #78716c;
}

.timeline,
.kanban-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.timeline-item,
.kanban-card {
  border-radius: 24rpx;
  padding: 20rpx 22rpx;
  background: #fff;
  border: 1rpx solid rgba(245, 158, 11, 0.18);
}

.timeline-item-primary {
  background: linear-gradient(135deg, #dbeafe, #eff6ff);
  border-color: rgba(59, 130, 246, 0.16);
}

.timeline-title,
.kanban-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.timeline-meta,
.kanban-count {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #78716c;
}

.primary-action {
  margin-top: 8rpx;
  padding: 26rpx 0;
  text-align: center;
  border-radius: 999rpx;
  background: #2563eb;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(37, 99, 235, 0.28);
}
