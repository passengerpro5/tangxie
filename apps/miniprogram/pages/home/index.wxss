  display: inline-flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 12rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 245, 0.98);
  border: 1rpx solid rgba(205, 167, 132, 0.2);
  box-shadow:
    0 18rpx 38rpx rgba(100, 64, 34, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.planner-attachment-action {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  width: auto;
  min-width: 268rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(252, 245, 238, 0.98) 100%);
  border: 1rpx solid rgba(210, 172, 136, 0.16);
  box-shadow:
    0 10rpx 24rpx rgba(105, 69, 39, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.planner-attachment-action-cancel {
  background: rgba(246, 242, 238, 0.96);
  border-color: rgba(185, 164, 147, 0.16);
  box-shadow: none;
}

.planner-attachment-action-icon {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(255, 242, 230, 0.98) 0%, rgba(255, 235, 217, 0.96) 100%);
  border: 1rpx solid rgba(227, 186, 150, 0.22);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.planner-attachment-action-cancel .planner-attachment-action-icon {
  background: rgba(255, 255, 255, 0.78);
  border-color: rgba(187, 170, 156, 0.18);
}

.planner-attachment-glyph {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}

.planner-attachment-glyph-doc-sheet {
  position: absolute;
  left: 4rpx;
  top: 2rpx;
  width: 16rpx;
  height: 20rpx;
  border-radius: 6rpx;
  border: 2rpx solid #bb7647;
  background: rgba(255, 255, 255, 0.46);
  box-sizing: border-box;
}

.planner-attachment-glyph-doc-line {
  position: absolute;
  left: 7rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #bb7647;
}

.planner-attachment-glyph-doc-line-top {
  top: 9rpx;
  width: 10rpx;
}

.planner-attachment-glyph-doc-line-bottom {
  top: 14rpx;
  width: 8rpx;
}

.planner-attachment-glyph-image-frame {
  position: absolute;
  left: 3rpx;
  top: 3rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  border: 2rpx solid #b86f57;
  background: rgba(255, 255, 255, 0.42);
  box-sizing: border-box;
}

.planner-attachment-glyph-image-sun {
  position: absolute;
  right: 4rpx;
  top: 4rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #e29064;
}

.planner-attachment-glyph-image-mountain {
  position: absolute;
  left: 4rpx;
  bottom: 4rpx;
  width: 10rpx;
  height: 6rpx;
  border-left: 2rpx solid #b86f57;
  border-bottom: 2rpx solid #b86f57;
  transform: skewX(-28deg) rotate(-8deg);
  box-sizing: border-box;
}

.planner-attachment-glyph-text-line {
  position: absolute;
  left: 4rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #b4694c;
}

.planner-attachment-glyph-text-line-1 {
  top: 6rpx;
  width: 16rpx;
}

.planner-attachment-glyph-text-line-2 {
  top: 11rpx;
  width: 12rpx;
}

.planner-attachment-glyph-text-line-3 {
  top: 16rpx;
  width: 14rpx;
}

.planner-attachment-glyph-close-line {
  position: absolute;
  left: 4rpx;
  top: 11rpx;
  width: 16rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #8f7d70;
}

.planner-attachment-glyph-close-line-a {
  transform: rotate(45deg);
}

.planner-attachment-glyph-close-line-b {
  transform: rotate(-45deg);
}

.planner-attachment-action-text {
  flex: 1;
  min-width: 0;
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #3a2418;
}

.planner-attachment-action-cancel .planner-attachment-action-text {
  color: #7e695d;
}

.planner-attachment-action-arrow {
  width: 12rpx;
  height: 12rpx;
  flex: none;
  border-top: 2rpx solid rgba(192, 138, 97, 0.82);
  border-right: 2rpx solid rgba(192, 138, 97, 0.82);
  transform: rotate(45deg);
}

.planner-attachment-action-cancel .planner-attachment-action-arrow {
  display: none;
}

.planner-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.planner-attachment-chip {
  padding: 10rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(241, 154, 95, 0.1);
  color: #b25f35;
}

.planner-attachment-name {
  font-size: 22rpx;
  line-height: 1.2;
}

.planner-composer-shell {
  display: block;
  padding: 4rpx;
  border-radius: 53rpx;
  background: rgba(255, 252, 248, 0.98);
  border: 1rpx solid rgba(223, 194, 169, 0.7);
  box-shadow:
    0 18rpx 42rpx rgba(108, 73, 44, 0.12),
    0 2rpx 10rpx rgba(255, 255, 255, 0.82) inset;
}

.planner-input-shell {
  width: 100%;
  min-height: 98rpx;
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  padding: 10rpx 12rpx 10rpx 16rpx;
  border-radius: 49rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
  box-sizing: border-box;
}

.planner-input-shell-ready {
  align-items: center;
}

.planner-tool {
  width: 36px;
  height: 36px;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: transparent;
  border: 0;
}

.planner-tool-inline {
  align-self: flex-end;
  margin-bottom: 0;
}

.planner-tool-mark {
  font-size: 32px;
  line-height: 1;
  font-weight: 300;
  color: #c4875f;
}

.planner-input,
.planner-ready-copy {
  flex: 1;
  min-height: 76rpx;
  padding: 16rpx 6rpx 14rpx 0;
  border-radius: 0;
  background: transparent;
  border: 0;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #342219;
}

.planner-input-answer {
  min-height: 76rpx;
}

.planner-ready-copy {
  display: flex;
  align-items: center;
  color: #8d6a52;
}

.planner-send-inline {
  flex: none;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  align-self: flex-end;
}

.planner-send-inline-button {
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(250, 220, 194, 0.98) 0%, rgba(247, 208, 176, 0.98) 100%);
  border: 0;
  color: transparent;
  font-size: 0;
  line-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 8rpx 18rpx rgba(197, 139, 97, 0.18),
    inset 0 1rpx 0 rgba(255, 248, 242, 0.9);
}

.planner-send-inline-button::after {
  border: 0;
}

.planner-send-inline-icon {
  width: 36rpx;
  height: 37rpx;
  flex: none;
  transform: translateY(-1rpx);
  opacity: 1;
}

.planner-send-inline-label {
  min-width: 72rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(241, 154, 95, 0.12);
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #b35d34;
  text-align: right;
}

.planner-send-inline-label-disabled,
.planner-send-inline-button[disabled] {
  opacity: 1;
}

.planner-send-inline-button[disabled] {
  background: linear-gradient(180deg, rgba(249, 224, 206, 0.98) 0%, rgba(246, 209, 184, 0.98) 100%);
  box-shadow: none;
}

.planner-send-inline-button[disabled] .planner-send-inline-icon {
  opacity: 0.42;
}

.planner-runtime-config {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(247, 248, 250, 0.92);
  border: 1rpx solid rgba(20, 20, 20, 0.06);
}

.planner-runtime-config-kicker {
  display: block;
  font-size: 20rpx;
  line-height: 1.2;
  color: #7a8291;
}

.planner-runtime-config-value {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #1f1f1f;
  word-break: break-all;
}

.planner-runtime-config-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
}

.planner-runtime-config-input {
  flex: 1;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid rgba(20, 20, 20, 0.08);
  box-sizing: border-box;
  font-size: 24rpx;
  color: #1f1f1f;
}

.planner-runtime-config-save {
  min-width: 108rpx;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #1f1f1f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.planner-runtime-config-save-label {
  font-size: 24rpx;
  line-height: 1;
  color: #fff;
  font-weight: 700;
}
