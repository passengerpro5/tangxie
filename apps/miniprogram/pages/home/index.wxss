.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.08) 34%, transparent 60%),
    linear-gradient(180deg, #efefef 0%, #e7e7e7 100%);
  color: #1f1f1f;
}

.workspace {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 12rpx 24rpx 228rpx;
}

.planner-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  z-index: 60;
  max-width: 520rpx;
  padding: 22rpx 28rpx;
  border-radius: 22rpx;
  transform: translate(-50%, -50%);
  background: rgba(28, 31, 36, 0.86);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(16rpx);
}

.planner-toast text {
  display: block;
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.planner-toast-error {
  background: rgba(150, 44, 28, 0.88);
}

.workspace-card {
  overflow: hidden;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(20, 20, 20, 0.08);
  box-shadow: 0 18rpx 54rpx rgba(20, 20, 20, 0.09);
}

.tab-strip {
  display: flex;
  align-items: flex-end;
  gap: 26rpx;
  padding: 22rpx 22rpx 10rpx;
  border-bottom: 1rpx solid rgba(20, 20, 20, 0.08);
}

.tab-item {
  padding-bottom: 10rpx;
  border-bottom: 4rpx solid transparent;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #677083;
}

.tab-item-active {
  color: #245ee8;
  border-bottom-color: #245ee8;
}

.date-rail {
  display: flex;
  align-items: stretch;
  gap: 0;
  min-width: max-content;
  padding: 14rpx 0 12rpx;
  border-bottom: 1rpx solid rgba(20, 20, 20, 0.08);
  background: linear-gradient(180deg, rgba(244, 244, 244, 0.7) 0%, rgba(255, 255, 255, 0) 100%);
}

.date-rail-timezone {
  width: 88rpx;
  display: flex;
  align-items: flex-end;
  padding-bottom: 24rpx;
}

.date-rail-timezone-label {
  font-size: 20rpx;
  line-height: 1;
  color: #8b8f97;
}

.date-rail-day {
  width: 176rpx;
  flex: none;
  padding: 4rpx 0 8rpx;
  text-align: center;
}

.date-rail-day-active {
  color: #245ee8;
}

.date-rail-day-past {
  color: #adb3bc;
}

.date-rail-week {
  display: block;
  font-size: 20rpx;
  line-height: 1.2;
  color: inherit;
}

.date-rail-date {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: inherit;
}

.date-rail-icon {
  width: 76rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 2rpx;
}

.date-rail-icon-mark {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.18);
  background: #fff;
  color: #657189;
  font-size: 16rpx;
  line-height: 30rpx;
  text-align: center;
}

.timeline-panel,
.kanban-panel {
  padding: 18rpx 16rpx 20rpx;
}

.timeline-stage {
  display: flex;
  flex-direction: column;
}

.timeline-stage-head {
  display: flex;
  gap: 0 10rpx;
  align-items: flex-end;
}

.timeline-stage-body {
  display: flex;
  gap: 0 10rpx;
  align-items: flex-start;
}

.timeline-gutter-head {
  width: 88rpx;
  flex: none;
}

.timeline-viewport {
  height: 980rpx;
}

.timeline-gutter-shell {
  width: 88rpx;
  flex: none;
}

.timeline-gutter {
  position: relative;
  width: 100%;
}

.timeline-hour {
  position: absolute;
  left: 0;
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  transform: translateY(-10rpx);
}

.timeline-hour-label {
  font-size: 20rpx;
  line-height: 1;
  color: #8c919a;
}

.timeline-scroll {
  flex: 1;
  min-width: 0;
}

.timeline-scroll-head {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.timeline-scroll-head-inner {
  min-width: max-content;
  will-change: transform;
}

.timeline-scroll-inner {
  min-width: max-content;
}

.timeline-days {
  display: flex;
  align-items: stretch;
  min-width: max-content;
}

.timeline-day-column {
  position: relative;
  width: 176rpx;
  flex: none;
  border-left: 1rpx solid rgba(20, 20, 20, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.6) 0%, rgba(251, 251, 251, 0.9) 100%);
}

.timeline-day-column-past {
  background: linear-gradient(180deg, rgba(245, 245, 245, 0.82) 0%, rgba(239, 239, 239, 0.92) 100%);
}

.timeline-grid-line {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1rpx solid rgba(20, 20, 20, 0.07);
}

.timeline-block {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  display: flex;
  align-items: stretch;
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(36, 101, 242, 0.18);
  background: rgba(232, 239, 255, 0.78);
}

.timeline-block-scheduled {
  border-color: rgba(36, 101, 242, 0.18);
  background: rgba(214, 226, 255, 0.86);
}

.timeline-block-needs_info {
  border-color: rgba(219, 132, 42, 0.2);
  background: rgba(255, 241, 224, 0.88);
}

.timeline-block-done {
  border-color: rgba(109, 118, 130, 0.15);
  background: rgba(242, 243, 246, 0.9);
}

.timeline-block-past {
  border-color: rgba(163, 168, 176, 0.18);
  background: rgba(234, 236, 240, 0.92);
}

.timeline-block-body {
  flex: 1;
  min-width: 0;
}

.timeline-block-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.timeline-block-title,
.kanban-column-title,
.timeline-empty-title,
.planner-sheet-title,
.planner-message-title,
.planner-history-title,
.planner-confirmed-name,
.planner-launch-title,
.planner-attachment-action-label {
  display: block;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #171717;
}

.timeline-block-chip,
.kanban-column-count {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(36, 101, 242, 0.12);
  color: #245ee8;
  font-size: 20rpx;
  font-weight: 700;
}

.timeline-block-time,
.timeline-block-copy,
.kanban-column-empty,
.timeline-empty-copy,
.planner-sheet-subtitle,
.planner-message-attachment,
.planner-history-summary,
.planner-history-time,
.planner-confirmed-time,
.planner-launch-subtitle,
.planner-ready-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #626b75;
}

.planner-message-body {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #626b75;
  white-space: pre-wrap;
  word-break: break-word;
}

.timeline-empty {
  padding: 48rpx 8rpx 12rpx;
}

.timeline-empty-title {
  font-size: 30rpx;
}

.kanban-columns {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.kanban-column {
  padding: 18rpx;
  border-radius: 26rpx;
  background: rgba(247, 248, 250, 0.95);
  border: 1rpx solid rgba(20, 20, 20, 0.06);
}

.kanban-column-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.kanban-chip-list {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.kanban-chip {
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid rgba(20, 20, 20, 0.06);
}

.kanban-chip-title {
  font-size: 22rpx;
  line-height: 1.3;
  color: #2a2f36;
}

.planner-launch {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 16rpx;
  justify-content: center;
  min-height: 82rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #245ee8, #2f67f3);
  box-shadow: 0 16rpx 44rpx rgba(36, 94, 232, 0.3);
}

.planner-launch-icon {
  width: 34rpx;
  height: 34rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.planner-launch-plus {
  font-size: 28rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.9);
}

.planner-launch-copy {
  flex: none;
}

.planner-launch-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.planner-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(25, 29, 35, 0.28);
  backdrop-filter: blur(8rpx);
  opacity: 0;
  transition: opacity 220ms ease;
}

.planner-mask-open {
  opacity: 1;
}

.planner-mask-closing {
  opacity: 0;
}

.planner-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  height: 75vh;
  padding: 0;
  box-sizing: border-box;
  transform: translateY(100%);
  opacity: 0.98;
}

.planner-sheet-surface {
  height: 100%;
  display: flex;
  flex-direction: column;
  border-radius: 34rpx 34rpx 0 0;
  background: linear-gradient(180deg, #ffffff 0%, #f7f8fb 100%);
  box-shadow: 0 -18rpx 48rpx rgba(20, 20, 20, 0.16);
  overflow: hidden;
  transform: translateY(0);
  transition:
    transform 280ms cubic-bezier(0.22, 1.08, 0.3, 1),
    opacity 220ms ease;
}

.planner-sheet-open .planner-sheet-surface {
  transform: translateY(0);
  opacity: 1;
}

.planner-sheet .planner-sheet-surface {
  transform: translateY(42rpx);
}

.planner-sheet-closing .planner-sheet-surface {
  transform: translateY(100rpx);
  opacity: 0.98;
}

.planner-sheet-open {
  transform: translateY(0);
  opacity: 1;
}

.planner-sheet-handle {
  width: 100rpx;
  height: 10rpx;
  margin: 16rpx auto 10rpx;
  border-radius: 999rpx;
  background: rgba(20, 20, 20, 0.12);
}

.planner-tab-strip {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 24rpx 14rpx;
}

.planner-tab-group {
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  min-width: 0;
}

.planner-tab-item {
  padding-bottom: 12rpx;
  border-bottom: 4rpx solid transparent;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #8a9099;
}

.planner-tab-item-primary {
  font-size: 32rpx;
  font-weight: 800;
  color: #171717;
}

.planner-tab-item-secondary {
  padding-top: 6rpx;
}

.planner-tab-item-active {
  color: #171717;
  border-bottom-color: #245ee8;
}

.planner-new-conversation {
  flex: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 4rpx 8rpx;
}

.planner-new-conversation-text {
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #245ee8;
}

.planner-thread {
  flex: 1;
  min-height: 0;
  padding: 0 18rpx 18rpx;
  box-sizing: border-box;
}

.planner-thread-section {
  margin-bottom: 14rpx;
}

.planner-thread-kicker {
  display: block;
  margin: 8rpx 6rpx 12rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #666d79;
  font-weight: 700;
}

.planner-history-card,
.planner-message {
  margin-bottom: 14rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(20, 20, 20, 0.06);
}

.planner-history-card {
  background: rgba(247, 248, 250, 0.96);
}

.planner-history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.planner-history-summary {
  margin-top: 8rpx;
}

.planner-message-system {
  margin-right: 72rpx;
}

.planner-message-user_input {
  align-self: flex-end;
  max-width: 82%;
  margin-left: 88rpx;
  padding: 18rpx 22rpx;
  border-radius: 28rpx;
  background: #edf2ff;
  border: 1rpx solid rgba(36, 94, 232, 0.1);
  box-shadow: 0 8rpx 20rpx rgba(36, 94, 232, 0.08);
}

.planner-message-assistant_message {
  align-self: flex-start;
  max-width: 100%;
  padding: 6rpx 0 2rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.planner-message-hero {
  background: linear-gradient(180deg, rgba(36, 101, 242, 0.08) 0%, rgba(36, 101, 242, 0.04) 100%);
}

.planner-message-extracted_attachment {
  background: rgba(255, 255, 255, 0.96);
}

.planner-message-system_question {
  margin-left: 72rpx;
  background: rgba(255, 255, 255, 0.98);
}

.planner-message-ready {
  background: rgba(235, 241, 255, 0.96);
}

.planner-message-attachment {
  color: #245ee8;
}

.planner-conversation {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-bottom: 8rpx;
}

.planner-message-user_input .planner-message-body {
  margin-top: 0;
  color: #171717;
}

.planner-message-assistant_message .planner-message-title {
  margin-bottom: 6rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #6f7682;
}

.planner-message-assistant_message .planner-message-body {
  margin-top: 0;
  font-size: 31rpx;
  line-height: 1.65;
  color: #171717;
}

.planner-confirmed-row {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(20, 20, 20, 0.06);
}

.planner-composer {
  padding: 16rpx 16rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(20, 20, 20, 0.08);
  background: rgba(255, 255, 255, 0.98);
  position: relative;
}

.planner-attachment-actions {
  position: absolute;
  left: 20rpx;
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  z-index: 5;
}

.planner-attachment-menu {
  display: inline-flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(20, 20, 20, 0.06);
  box-shadow: 0 12rpx 30rpx rgba(20, 20, 20, 0.1);
}

.planner-attachment-action {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  width: auto;
  min-width: 0;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(247, 248, 250, 0.98);
}

.planner-attachment-action-cancel {
  background: rgba(244, 245, 247, 0.98);
}

.planner-attachment-action-icon {
  width: 28rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1;
  color: #657189;
}

.planner-attachment-action-text {
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #171717;
}

.planner-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.planner-attachment-chip {
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(36, 101, 242, 0.08);
  color: #245ee8;
}

.planner-attachment-name {
  font-size: 22rpx;
  line-height: 1.2;
}

.planner-composer-shell {
  display: block;
}

.planner-input-shell {
  width: 100%;
  min-height: 96rpx;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 10rpx 12rpx 10rpx 14rpx;
  border-radius: 28rpx;
  background: #f6f7fa;
  border: 1rpx solid rgba(20, 20, 20, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  box-sizing: border-box;
}

.planner-input-shell-ready {
  align-items: center;
}

.planner-tool {
  width: 64rpx;
  height: 64rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: transparent;
  border: 0;
}

.planner-tool-inline {
  margin-bottom: 2rpx;
}

.planner-tool-mark {
  font-size: 42rpx;
  line-height: 1;
  font-weight: 300;
  color: #7b818b;
}

.planner-input,
.planner-ready-copy {
  flex: 1;
  min-height: 76rpx;
  padding: 16rpx 4rpx 16rpx 0;
  border-radius: 0;
  background: transparent;
  border: 0;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #1f1f1f;
}

.planner-input-answer {
  min-height: 76rpx;
}

.planner-ready-copy {
  display: flex;
  align-items: center;
  color: #7b818b;
}

.planner-send-inline {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.planner-send-inline-button {
  width: 68rpx;
  height: 68rpx;
  min-width: 68rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(20, 20, 20, 0.06);
  color: #171717;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(20, 20, 20, 0.08);
}

.planner-send-inline-button::after {
  border: 0;
}

.planner-send-inline-label {
  min-width: 72rpx;
  padding: 0 8rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #9aa1ab;
  text-align: right;
}

.planner-runtime-config {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(247, 248, 250, 0.92);
  border: 1rpx solid rgba(20, 20, 20, 0.06);
}

.planner-runtime-config-kicker {
  display: block;
  font-size: 20rpx;
  line-height: 1.2;
  color: #7a8291;
}

.planner-runtime-config-value {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #1f1f1f;
  word-break: break-all;
}

.planner-runtime-config-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
}

.planner-runtime-config-input {
  flex: 1;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid rgba(20, 20, 20, 0.08);
  box-sizing: border-box;
  font-size: 24rpx;
  color: #1f1f1f;
}

.planner-runtime-config-save {
  min-width: 108rpx;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #1f1f1f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.planner-runtime-config-save-label {
  font-size: 24rpx;
  line-height: 1;
  color: #fff;
  font-weight: 700;
}
