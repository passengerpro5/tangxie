.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(255, 247, 239, 0.92) 0%, rgba(255, 247, 239, 0.16) 34%, transparent 62%),
    linear-gradient(180deg, #fbf5ee 0%, #f4eadf 100%);
  color: #3c2f28;
}

.workspace {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 18rpx 24rpx 228rpx;
}

.planner-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  z-index: 60;
  max-width: 520rpx;
  padding: 22rpx 28rpx;
  border-radius: 22rpx;
  transform: translate(-50%, -50%);
  background: rgba(28, 31, 36, 0.86);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(16rpx);
}

.planner-toast text {
  display: block;
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.planner-toast-error {
  background: rgba(150, 44, 28, 0.88);
}

.workspace-card {
  overflow: hidden;
  border-radius: 40rpx;
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.96) 0%, rgba(252, 247, 240, 0.96) 100%);
  border: 1rpx solid rgba(127, 89, 53, 0.08);
  box-shadow: 0 20rpx 54rpx rgba(108, 75, 42, 0.1);
}

.surface-shell {
  padding: 18rpx 18rpx 20rpx;
}

.primary-tabs {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.primary-tabs-floating {
  margin-bottom: 16rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.92);
  border: 1rpx solid rgba(127, 89, 53, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

.primary-tab {
  min-width: 0;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #8b684e;
}

.primary-tab-active {
  color: #fff9f4;
  background: linear-gradient(135deg, #ffb15c 0%, #ff8c68 100%);
  box-shadow: 0 10rpx 24rpx rgba(235, 138, 88, 0.24);
}

.surface-panel {
  border-radius: 34rpx;
}

.planning-panel,
.timeline-panel,
.kanban-panel {
  padding: 0 0 4rpx;
}

.control-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
  padding: 4rpx 2rpx;
}

.control-strip-meta-only {
  justify-content: flex-end;
}

.control-strip-compact {
  margin-bottom: 12rpx;
}

.control-strip-main,
.control-strip-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.control-strip-meta {
  flex: none;
}

.control-chip,
.control-pill {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(127, 89, 53, 0.08);
  background: rgba(255, 248, 240, 0.94);
}

.control-chip text,
.control-pill text {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #9a6f4c;
}

.control-chip-active {
  background: linear-gradient(135deg, rgba(255, 191, 114, 0.24) 0%, rgba(255, 144, 106, 0.22) 100%);
  border-color: rgba(237, 145, 92, 0.14);
}

.control-caption {
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.35;
  color: #84644d;
}

.schedule-summary {
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 249, 242, 0.96);
  border: 1rpx solid rgba(127, 89, 53, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.65);
}

.schedule-summary-expanded {
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.65),
    0 12rpx 28rpx rgba(153, 108, 67, 0.08);
}

.schedule-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.schedule-summary-heading {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.schedule-summary-metrics,
.schedule-summary-detail {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  min-width: 0;
}

.schedule-summary-detail {
  margin-top: 12rpx;
}

.summary-metric {
  display: inline-flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 242, 230, 0.9);
}

.summary-metric-expanded {
  padding-right: 14rpx;
}

.summary-metric-value {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #965a39;
}

.summary-metric-label,
.schedule-summary-toggle text {
  font-size: 20rpx;
  line-height: 1.2;
  color: #8d6c55;
}

.schedule-summary-toggle {
  flex: none;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.schedule-summary-toggle-icon {
  display: block;
  width: 12rpx;
  height: 12rpx;
  border-right: 3rpx solid #9a775b;
  border-bottom: 3rpx solid #9a775b;
  box-sizing: border-box;
  transform: rotate(45deg);
  transform-origin: center;
  transition: transform 180ms ease;
}

.schedule-summary-toggle-icon-expanded {
  transform: rotate(-135deg);
}

.date-rail {
  display: flex;
  align-items: stretch;
  gap: 0;
  min-width: max-content;
  padding: 16rpx 0 12rpx;
  border-bottom: 1rpx solid rgba(127, 89, 53, 0.08);
  background: linear-gradient(180deg, rgba(255, 247, 239, 0.84) 0%, rgba(255, 252, 247, 0.4) 100%);
}

.date-rail-control {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 22rpx;
}

.timeline-day-range-trigger {
  width: 72rpx;
  height: 72rpx;
  border: 0;
  background: transparent;
  box-shadow: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.timeline-day-range-trigger-hover {
  opacity: 0.76;
}

.timeline-day-range-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  border: 3rpx solid #b58463;
  background: transparent;
  box-sizing: border-box;
}

.timeline-day-range-icon-rings {
  position: absolute;
  top: -8rpx;
  left: 8rpx;
  right: 8rpx;
  display: flex;
  justify-content: space-between;
}

.timeline-day-range-icon-ring {
  width: 6rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #b58463;
}

.timeline-day-range-icon-grid {
  position: absolute;
  inset: 11rpx 8rpx 6rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 5rpx;
}

.timeline-day-range-icon-dot {
  border-radius: 999rpx;
  background: rgba(181, 132, 99, 0.72);
}

.timeline-day-range-menu {
  position: absolute;
  top: calc(100% - 4rpx);
  left: 0;
  z-index: 6;
  min-width: 124rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(178, 136, 100, 0.14);
  background: linear-gradient(180deg, rgba(255, 251, 247, 0.98) 0%, rgba(255, 245, 236, 0.96) 100%);
  box-shadow: 0 20rpx 40rpx rgba(161, 108, 65, 0.16);
}

.timeline-day-range-option {
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
}

.timeline-day-range-option + .timeline-day-range-option {
  margin-top: 6rpx;
}

.timeline-day-range-option-active {
  background: linear-gradient(180deg, rgba(255, 238, 220, 0.96) 0%, rgba(255, 226, 201, 0.94) 100%);
}

.timeline-day-range-option-label {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  color: #8f735d;
}

.timeline-day-range-option-active .timeline-day-range-option-label {
  color: #cb7650;
  font-weight: 700;
}

.date-rail-day {
  flex: none;
  padding: 4rpx 0 8rpx;
  text-align: center;
}

.date-rail-day-active {
  color: #cb7650;
}

.date-rail-day-past {
  color: #c6b4a7;
}

.date-rail-week {
  display: block;
  font-size: 20rpx;
  line-height: 1.2;
  color: inherit;
}

.date-rail-date {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: inherit;
}

.timeline-panel-chip {
  border-radius: 24rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.06);
}

.timeline-panel-head,
.planning-analysis-row,
.planning-legend {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.timeline-panel-title,
.planning-analysis-title,
.planning-task-column-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #171717;
}

.timeline-panel-copy,
.planning-analysis-label,
.planning-legend-label {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #626b75;
}

.timeline-panel-chip {
  flex: none;
  padding: 10rpx 18rpx;
  background: rgba(36, 94, 232, 0.08);
}

.timeline-panel-chip text {
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #245ee8;
}

.planning-task-column-subtitle,
.planning-task-bar-copy {
  display: block;
  font-size: 23rpx;
  line-height: 1.45;
  color: #626b75;
}

.timeline-stage {
  display: flex;
  flex-direction: column;
}

.timeline-stage-head {
  display: flex;
  gap: 0 10rpx;
  align-items: flex-end;
}

.timeline-stage-body {
  display: flex;
  gap: 0 10rpx;
  align-items: flex-start;
}

.timeline-gutter-head {
  width: 88rpx;
  flex: none;
  position: relative;
  z-index: 6;
}

.timeline-viewport {
  height: 980rpx;
}

.timeline-gutter-shell {
  width: 88rpx;
  flex: none;
}

.timeline-gutter {
  position: relative;
  width: 100%;
}

.timeline-hour {
  position: absolute;
  left: 0;
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  transform: translateY(-10rpx);
}

.timeline-hour-label {
  font-size: 20rpx;
  line-height: 1;
  color: #8c919a;
}

.timeline-scroll {
  flex: 1;
  min-width: 0;
}

.timeline-scroll-head {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.timeline-scroll-head-inner {
  min-width: max-content;
  will-change: transform;
}

.timeline-scroll-inner {
  min-width: max-content;
}

.timeline-days {
  display: flex;
  align-items: stretch;
  min-width: max-content;
}

.timeline-day-column {
  position: relative;
  flex: none;
  border-left: 1rpx solid rgba(175, 137, 102, 0.08);
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.72) 0%, rgba(255, 246, 237, 0.94) 100%);
}

.timeline-day-column-past {
  background: linear-gradient(180deg, rgba(247, 242, 236, 0.86) 0%, rgba(241, 234, 226, 0.94) 100%);
}

.timeline-grid-line {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1rpx solid rgba(180, 145, 113, 0.08);
}

.timeline-block {
  position: absolute;
  left: 0;
  right: 0;
  transform: translateY(2px);
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  padding: 16rpx 16rpx 14rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(222, 168, 118, 0.26);
  background: linear-gradient(180deg, rgba(255, 251, 246, 0.98) 0%, rgba(255, 244, 232, 0.94) 100%);
  box-shadow:
    0 10rpx 24rpx rgba(162, 111, 67, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
  transition:
    background 160ms ease,
    box-shadow 160ms ease,
    transform 160ms ease,
    border-color 160ms ease;
}

.timeline-block-hover {
  background: linear-gradient(180deg, rgba(255, 247, 238, 1) 0%, rgba(255, 237, 220, 0.96) 100%);
  border-color: rgba(224, 144, 92, 0.34);
  box-shadow:
    0 14rpx 28rpx rgba(178, 118, 75, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
}

.timeline-block-scheduled {
  border-color: rgba(225, 150, 102, 0.28);
  background: linear-gradient(180deg, rgba(255, 246, 236, 0.98) 0%, rgba(255, 236, 220, 0.95) 100%);
}

.timeline-block-needs_info {
  border-color: rgba(215, 141, 62, 0.28);
  background: linear-gradient(180deg, rgba(255, 243, 223, 0.98) 0%, rgba(255, 233, 196, 0.95) 100%);
}

.timeline-block-done {
  border-color: rgba(160, 152, 140, 0.2);
  background: linear-gradient(180deg, rgba(245, 242, 238, 0.96) 0%, rgba(236, 231, 225, 0.94) 100%);
}

.timeline-block-past {
  border-color: rgba(187, 171, 153, 0.2);
  background: linear-gradient(180deg, rgba(243, 238, 232, 0.94) 0%, rgba(234, 227, 220, 0.92) 100%);
  box-shadow: none;
}

.timeline-block-editing {
  z-index: 3;
  border-color: rgba(229, 134, 78, 0.56);
  box-shadow:
    0 16rpx 34rpx rgba(214, 130, 82, 0.18),
    0 0 0 4rpx rgba(247, 198, 157, 0.22);
}

.timeline-block-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.timeline-block-resize {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  height: 28rpx;
  border-radius: 999rpx;
  z-index: 4;
}

.timeline-block-resize::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 96rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(216, 143, 88, 0.28);
  transform: translate(-50%, -50%);
}

.timeline-block-resize-top {
  top: -8rpx;
}

.timeline-block-resize-bottom {
  bottom: -8rpx;
}

.timeline-block-resize-active::after {
  background: rgba(223, 126, 72, 0.72);
}

.timeline-block-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 2rpx;
}

.timeline-block-title,
.kanban-column-title,
.timeline-empty-title,
.planner-sheet-title,
.planner-message-title,
.planner-history-title,
.planner-confirmed-name,
.planner-launch-title,
.planner-attachment-action-label {
  display: block;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #171717;
}

.timeline-block-chip,
.kanban-column-count {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(36, 101, 242, 0.12);
  color: #245ee8;
  font-size: 20rpx;
  font-weight: 700;
}

.timeline-block-time,
.timeline-block-copy,
.kanban-column-empty,
.timeline-empty-copy,
.planner-sheet-subtitle,
.planner-message-attachment,
.planner-history-summary,
.planner-history-time,
.planner-confirmed-time,
.planner-launch-subtitle,
.planner-ready-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #626b75;
}

.timeline-block-title {
  font-size: 30rpx;
  line-height: 1.3;
  color: #4c3427;
}

.timeline-block-time {
  margin-top: 0;
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #7b5740;
}

.timeline-block-deadline {
  margin-top: 0;
  display: inline-flex;
  align-items: center;
  width: fit-content;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.56);
  font-size: 20rpx;
  line-height: 1.2;
  color: #96674b;
}

.planner-message-body {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #626b75;
  white-space: pre-wrap;
  word-break: break-word;
}

.timeline-empty {
  padding: 48rpx 8rpx 12rpx;
}

.planning-toolbar {
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  margin-bottom: 18rpx;
  padding: 8rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(127, 89, 53, 0.08);
  background: linear-gradient(180deg, rgba(255, 251, 246, 0.96) 0%, rgba(255, 246, 238, 0.9) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 12rpx 30rpx rgba(154, 106, 67, 0.06);
}

.planning-toolbar-main {
  flex: 0 0 246rpx;
  min-width: 0;
}

.planning-period-strip {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(127, 89, 53, 0.06);
  background: rgba(255, 250, 244, 0.8);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  overflow: hidden;
}

.planning-range-badge {
  height: 100%;
  min-height: 84rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  border-radius: 22rpx;
  border: 1rpx solid rgba(127, 89, 53, 0.08);
  background: linear-gradient(180deg, rgba(255, 249, 242, 0.96) 0%, rgba(255, 244, 235, 0.94) 100%);
  box-shadow:
    0 8rpx 18rpx rgba(165, 115, 74, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.76);
  box-sizing: border-box;
}

.planning-range-label {
  display: block;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #8b684e;
  letter-spacing: 0.4rpx;
  word-break: break-word;
}

.planning-period-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  min-height: 72rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
  background: transparent;
  color: #8b684e;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  text-align: center;
}

.planning-period-chip-active {
  border-color: rgba(237, 145, 92, 0.18);
  background: linear-gradient(135deg, #ffb15c 0%, #ff8c68 100%);
  color: #fff9f4;
  box-shadow: 0 10rpx 22rpx rgba(235, 138, 88, 0.18);
}

.planning-gantt {
  border-radius: 28rpx;
  background: rgba(247, 248, 250, 0.96);
  border: 1rpx solid rgba(20, 20, 20, 0.06);
  overflow: hidden;
}

.planning-gantt-viewport {
  height: 980rpx;
}

.planning-gantt-shell {
  display: flex;
  align-items: flex-start;
}

.planning-gantt-axis {
  position: relative;
  width: 96rpx;
  flex: none;
  border-right: 1rpx solid rgba(20, 20, 20, 0.06);
  background: rgba(255, 255, 255, 0.82);
}

.planning-gantt-axis-slot {
  position: absolute;
  left: 0;
  right: 0;
  transform: translateY(-10rpx);
}

.planning-gantt-axis-label {
  display: block;
  padding-left: 14rpx;
  font-size: 20rpx;
  line-height: 1;
  color: #8c919a;
}

.planning-gantt-scroll {
  flex: 1;
  min-width: 0;
}

.planning-gantt-columns {
  display: flex;
  align-items: stretch;
  min-width: max-content;
}

.planning-task-column {
  width: 188rpx;
  flex: none;
  border-left: 1rpx solid rgba(165, 122, 84, 0.08);
  background: linear-gradient(180deg, rgba(255, 250, 245, 0.82) 0%, rgba(255, 245, 236, 0.94) 100%);
}

.planning-task-column-head {
  min-height: 108rpx;
  padding: 18rpx 14rpx 12rpx;
  border-bottom: 1rpx solid rgba(165, 122, 84, 0.08);
}

.planning-task-column-subtitle {
  margin-top: 8rpx;
}

.planning-task-track {
  position: relative;
}

.planning-task-grid-line {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1rpx solid rgba(165, 122, 84, 0.08);
}

.planning-task-bar {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7b062 0%, #f78d68 100%);
  box-shadow: 0 12rpx 22rpx rgba(226, 135, 91, 0.24);
}

.planning-task-bar-body {
  padding: 14rpx 14rpx 12rpx;
}

.planning-task-bar-title {
  display: block;
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #fff;
}

.planning-task-bar-copy {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.9);
}

.timeline-empty-title {
