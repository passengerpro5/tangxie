.detail-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at top, rgba(255, 220, 188, 0.38), transparent 44%),
    linear-gradient(180deg, #fffaf3 0%, #fff1df 100%);
  color: #5b3c2b;
}

.detail-shell {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-hero,
.detail-section-card,
.detail-history-card {
  border: 1rpx solid rgba(239, 202, 168, 0.88);
  background: rgba(255, 252, 247, 0.9);
  box-shadow: 0 16rpx 36rpx rgba(162, 111, 67, 0.08);
}

.detail-hero {
  padding: 28rpx;
  border-radius: 34rpx;
  animation: detail-rise 240ms ease-out both;
}

.detail-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  flex-wrap: wrap;
}

.detail-hero-kicker,
.detail-hero-badge,
.detail-section-kicker {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.detail-hero-kicker {
  padding: 10rpx 16rpx;
  background: rgba(255, 222, 188, 0.72);
  color: #a86428;
  font-weight: 700;
}

.detail-hero-badge {
  padding: 10rpx 16rpx;
  background: rgba(255, 244, 232, 0.92);
  color: #8a5c41;
}

.detail-title {
  display: block;
  margin-top: 16rpx;
  font-size: 44rpx;
  line-height: 1.22;
  font-weight: 700;
  color: #4a3326;
}

.detail-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #7c5b47;
}

.detail-primary-meta {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.detail-primary-meta-card {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #fff6ea;
}

.detail-primary-meta-card-focus {
  background: linear-gradient(135deg, #fff0dc 0%, #fff6ea 100%);
}

.detail-meta-label {
  display: block;
  font-size: 22rpx;
  line-height: 1.4;
  color: #b47a48;
}

.detail-meta-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #563a29;
}

.detail-parent-line {
  display: flex;
  gap: 12rpx;
  align-items: baseline;
  flex-wrap: wrap;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx dashed rgba(220, 181, 145, 0.75);
}

.detail-parent-label {
  font-size: 24rpx;
  color: #b0805c;
}

.detail-parent-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #5f412f;
}

.detail-meta-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.detail-meta-tile {
  width: calc(50% - 7rpx);
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 252, 248, 0.94);
  border: 1rpx solid rgba(244, 214, 182, 0.84);
  box-shadow: 0 12rpx 24rpx rgba(161, 107, 65, 0.06);
  box-sizing: border-box;
}

.detail-meta-tile-wide {
  width: 100%;
}

.detail-section-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-section-card,
.detail-history-card {
  padding: 24rpx;
  border-radius: 32rpx;
}

.detail-section-head {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.detail-section-kicker {
  padding: 8rpx 14rpx;
  background: rgba(255, 230, 205, 0.88);
  color: #a46d3d;
  font-weight: 600;
}

.detail-section-title {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #4b3426;
}

.detail-section-copy {
  display: block;
  font-size: 24rpx;
  line-height: 1.65;
  color: #886651;
}

.detail-section-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-section-item {
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #fffaf6;
  border: 1rpx solid rgba(242, 220, 196, 0.8);
}

.detail-section-item-label {
  display: block;
  font-size: 22rpx;
  line-height: 1.4;
  color: #b27a52;
}

.detail-section-item-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5c4030;
}

.detail-history-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.detail-history-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  padding: 8rpx 0;
}

.detail-history-marker {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f6aa58 0%, #f87f63 100%);
  box-shadow: 0 0 0 10rpx rgba(249, 160, 98, 0.14);
}

.detail-history-body {
  flex: 1;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid rgba(232, 200, 170, 0.62);
}

.detail-history-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #543b2d;
}

.detail-history-summary {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #7d5c49;
}

.detail-history-time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #aa876d;
}

@keyframes detail-rise {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
